# ==========================================
# MergeMind (AI Slop Cleaner) Environment
# ==========================================

# 1. Pinecone Database (Vector Search)
# Get this from: https://app.pinecone.io/ (API Keys tab)
PINECONE_API_KEY=
# The exact name you gave your index (e.g. mergemind-index)
PINECONE_INDEX=
# Some serverless setups need an environment or host URL. If blank, SDKs use default host.
PINECONE_ENVIRONMENT=

# 2. E2B Sandbox (Code Execution & Validation)
# Get this from: https://e2b.dev/ (Dashboard -> API Keys -> Default)
E2B_API_KEY=

# 3. GitHub (Agent Control & PR Creation)
# Get this from: https://github.com/settings/tokens (Use Fine-Grained Token)
GITHUB_ACCESS_TOKEN=

# 4. LLM API (The Brain - Choose ONE or both)
# Option A: Google Gemini (Recommended for codebase intelligence)
# Get this from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Option B: OpenAI
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ==========================================
# Database & Redis Settings
# ==========================================
# BullMQ / Queue Connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Primary PostgreSQL Database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mergemind?schema=public"
